      "dac": { "ch": 1, "note": "DAC1 – Audio-Ausgang möglich (z.B. I2S interner DAC)" }
    },
    {
      "num": 26,
      "labels": ["GPIO26", "IO26", "D26"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
