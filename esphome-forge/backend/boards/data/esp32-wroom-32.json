      "rtc": false, "pwm": false, "flash": true,
      "notes": "SPI-Flash D2 – NICHT VERWENDEN!"
    },
    {
      "num": 10, "labels": ["GPIO10", "IO10", "SD3"],
      "input": false, "output": false, "od": false, "pu": false, "pd": false,
      "rtc": false, "pwm": false, "flash": true,
      "notes": "SPI-Flash D3 – NICHT VERWENDEN!"
    },
    {
      "num": 11, "labels": ["GPIO11", "IO11", "CMD"],
      "input": false, "output": false, "od": false, "pu": false, "pd": false,
      "rtc": false, "pwm": false, "flash": true,
      "notes": "SPI-Flash CMD – NICHT VERWENDEN!"
    },
    {
      "num": 12,
      "labels": ["GPIO12", "IO12", "D12", "MTDI"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 5, "wifi_ok": false },
      "touch": { "ch": 5 },
      "spi_hw": { "bus": "HSPI", "role": "MISO" },
      "strapping": "MTDI – wenn HIGH beim Boot: 1,8V Flash-Spannung → Boot-Fehler auf 3,3V-Boards! Immer LOW oder float lassen."
    },
    {
      "num": 13,
      "labels": ["GPIO13", "IO13", "D13", "MTCK"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 4, "wifi_ok": false },
      "touch": { "ch": 4 },
      "spi_hw": { "bus": "HSPI", "role": "MOSI" }
    },
    {
      "num": 14,
      "labels": ["GPIO14", "IO14", "D14", "MTMS"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 6, "wifi_ok": false },
      "touch": { "ch": 6 },
      "spi_hw": { "bus": "HSPI", "role": "CLK" },
      "notes": "Gibt beim Boot einen Takt-Puls aus."
    },
    {
      "num": 15,
      "labels": ["GPIO15", "IO15", "D15", "MTDO"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 3, "wifi_ok": false },
      "touch": { "ch": 3 },
      "spi_hw": { "bus": "HSPI", "role": "CS" },
