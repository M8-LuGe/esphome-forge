{
  "$schema": "../board.schema.json",
  "id": "esp32-wroom-32",
  "name": "ESP32-WROOM-32 DevKit v1",
  "aliases": ["ESP32 DevKit", "NodeMCU-32S", "esp32dev"],
  "manufacturer": "Espressif",
  "category": "devkit",
  "esphome_board": "esp32dev",
  "esphome_framework": ["arduino", "esp-idf"],
  "image_url": "https://docs.espressif.com/projects/esp-idf/en/latest/_images/esp32-devkitC-v4-pinout.png",
  "datasheet_url": "https://www.espressif.com/sites/default/files/documentation/esp32-wroom-32_datasheet_en.pdf",
  "chip": {
    "family": "ESP32",
    "model": "ESP32-D0WDQ6",
    "variant": "ESP32",
    "revision_min": 0,
    "cpu_cores": 2,
    "cpu_arch": "xtensa-lx6",
    "cpu_mhz": 240,
    "ram_kb": 520,
    "flash_mb": 4,
    "psram_mb": null,
    "psram_mode": null,
    "wifi": true,
    "bluetooth": "BT+BLE",
    "ethernet": false,
    "usb_native": false
  },
  "power": {
    "voltage_logic": 3.3,
    "voltage_input_min": 3.0,
    "voltage_input_max": 3.6
  },
  "notes": "GPIO6-11 sind intern mit dem SPI-Flash verbunden und dürfen NICHT verwendet werden. ADC2 (GPIO0,2,4,12-15,25-27) funktioniert nicht wenn WiFi aktiv ist – nur ADC1 (GPIO32-39) verwenden!",
  "community_url": "https://esphome.io/components/esp32.html",

  "builtin_components": [
    {
      "id": "onboard_led",
      "type": "led",
      "name": "Onboard LED",
      "esphome_platform": "gpio",
      "active_level": "high",
      "pins": {
        "led": { "gpio": 2, "role": "LED", "note": "Blau, an GPIO2 (auch Strapping-Pin)" }
      },
      "notes": "Nicht auf allen DevKit-Varianten vorhanden"
    }
  ],

  "gpios": [
    {
      "num": 0,
      "labels": ["GPIO0", "IO0", "D0"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 1, "wifi_ok": false },
      "touch": { "ch": 1 },
      "strapping": "Boot-Modus: LOW=Download-Modus, HIGH/Float=Normal-Boot. Intern 10kΩ Pull-up.",
      "notes": "Vorsicht bei Verwendung als Ausgang – beeinflusst Boot-Modus."
    },
    {
      "num": 1,
      "labels": ["GPIO1", "IO1", "TX0"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "uart_default": { "unit": 0, "role": "TX" },
      "notes": "UART0 TX (USB-Serial). Bei Verwendung kein Log-Output via USB."
    },
    {
      "num": 2,
      "labels": ["GPIO2", "IO2", "D2"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 2, "wifi_ok": false },
      "touch": { "ch": 2 },
      "strapping": "Muss beim Download-Modus LOW oder float sein. Mit internem Pull-down.",
      "notes": "Onboard-LED auf vielen DevKit-Varianten."
    },
    {
      "num": 3,
      "labels": ["GPIO3", "IO3", "RX0"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "uart_default": { "unit": 0, "role": "RX" },
      "notes": "UART0 RX (USB-Serial). HIGH beim Boot."
    },
    {
      "num": 4,
      "labels": ["GPIO4", "IO4", "D4"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 0, "wifi_ok": false },
      "touch": { "ch": 0 }
    },
    {
      "num": 5,
      "labels": ["GPIO5", "IO5", "D5"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "spi_hw": { "bus": "VSPI", "role": "CS" },
      "strapping": "SDIO-Slave Timing; 10kΩ Pull-up beim Boot."
    },
    {
      "num": 6,  "labels": ["GPIO6", "IO6", "CLK"],
      "input": false, "output": false, "od": false, "pu": false, "pd": false,
      "rtc": false, "pwm": false, "flash": true,
      "notes": "SPI-Flash CLK – NICHT VERWENDEN!"
    },
    {
      "num": 7,  "labels": ["GPIO7", "IO7", "SD0"],
      "input": false, "output": false, "od": false, "pu": false, "pd": false,
      "rtc": false, "pwm": false, "flash": true,
      "notes": "SPI-Flash D0 – NICHT VERWENDEN!"
    },
    {
      "num": 8,  "labels": ["GPIO8", "IO8", "SD1"],
