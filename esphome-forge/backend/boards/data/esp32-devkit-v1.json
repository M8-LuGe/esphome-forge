      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 1, "wifi_ok": false },
      "touch": { "ch": 1 },
      "strapping": "Boot-Modus: LOW=Download, HIGH=Normal. BOOT-Taster auf Platine (aktiv-LOW).",
