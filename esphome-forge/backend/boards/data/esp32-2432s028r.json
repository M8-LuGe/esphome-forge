      "board_usage": { "comp": "rgb_led", "role": "LED_B" }
    },
    {
      "num": 18,
      "labels": ["GPIO18"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "spi_hw": { "bus": "VSPI", "role": "CLK" },
      "board_usage": { "comp": "sd_card", "role": "CLK" }
    },
    {
      "num": 19,
      "labels": ["GPIO19"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "spi_hw": { "bus": "VSPI", "role": "MISO" },
      "board_usage": { "comp": "sd_card", "role": "MISO" }
    },
    {
      "num": 21,
      "labels": ["GPIO21"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "i2c_default": "SDA",
      "board_usage": { "comp": "display_ili9341", "role": "BACKLIGHT" }
    },
    {
      "num": 22,
      "labels": ["GPIO22"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "i2c_default": "SCL",
      "notes": "Frei! Empfohlen für I2S i2s_lrclk_pin (Speaker-Takt, nicht DAC-Ausgang)."
    },
    {
      "num": 23,
      "labels": ["GPIO23"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": false, "pwm": true,
      "spi_hw": { "bus": "VSPI", "role": "MOSI" },
      "board_usage": { "comp": "sd_card", "role": "MOSI" }
    },
    {
      "num": 25,
      "labels": ["GPIO25"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 8, "wifi_ok": false },
      "dac": { "ch": 1, "note": "DAC1 – intern durch I2S-DAC mitaktiviert wenn Speaker genutzt." },
      "board_usage": {
        "comp": "touch_xpt2046", "role": "CLK",
        "note": "Konflikt: GPIO25 = Touch-CLK + DAC1. I2S-Takt-Pins (lrclk/bclk) auf GPIO22/27 legen!"
      }
    },
    {
      "num": 26,
      "labels": ["GPIO26"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
      "rtc": true, "pwm": true,
      "adc": { "unit": 2, "ch": 9, "wifi_ok": false },
      "dac": { "ch": 2, "note": "DAC2/Left – Lautsprecher-Ausgang P4-Stecker. Im Silizium fest." },
      "board_usage": { "comp": "speaker", "role": "DAC2_LEFT" }
    },
    {
      "num": 27,
      "labels": ["GPIO27"],
      "input": true, "output": true, "od": true, "pu": true, "pd": true,
