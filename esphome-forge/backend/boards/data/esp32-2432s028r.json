      "touch": { "ch": 8 },
      "board_usage": { "comp": "touch_xpt2046", "role": "CS" }
    },
    {
      "num": 34,
      "labels": ["GPIO34"],
      "input": true, "output": false, "od": false, "pu": false, "pd": false,
      "rtc": true, "pwm": false,
      "adc": { "unit": 1, "ch": 6, "wifi_ok": true },
      "board_usage": { "comp": "ldr", "role": "ADC" }
    },
    {
      "num": 35,
      "labels": ["GPIO35"],
      "input": true, "output": false, "od": false, "pu": false, "pd": false,
